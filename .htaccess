Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On

ErrorDocument 403 /assets/error-pages/error.php?code=403
ErrorDocument 404 /assets/error-pages/error.php?code=404
ErrorDocument 500 /assets/error-pages/error.php?code=500
ErrorDocument 503 /assets/error-pages/error.php?code=503

# Preserve Authorization for PHP/FastCGI so CardDAV Basic auth reaches the app.
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Canonical service entry wrappers live under /system.
RewriteRule ^system/ajax/?$ system/ajax.php [L,QSA,NC]
RewriteRule ^system/cron/?$ system/cron.php [L,QSA,NC]
RewriteRule ^system/webhook/([A-Za-z0-9_-]+)/?$ system/webhooks.php?provider=$1 [L,QSA,NC]

# Module and runtime assets are protected by the front controller so module
# asset policy, content type, and cache headers remain consistent.
RewriteRule ^assets/(?:modules|runtime)(?:/|$) index.php [L,QSA,NC]

# Static public assets are stored under /system to keep the root compact.
RewriteRule ^assets/(.+)$ system/assets/$1 [L,QSA,NC]

# Portal-scoped AJAX endpoint must resolve before the front controller fallback.
RewriteRule ^metis/api/ajax/?$ index.php?metis_api_ajax=1 [L,QSA,NC]
RewriteRule ^api/ajax/?$ index.php?metis_api_ajax=1 [L,QSA,NC]

# Block direct requests into application internals and non-public storage.
RewriteRule (^|/)\.(?!well-known/) - [F,L]
RewriteRule ^(?:includes|logs|\.metis-integrity|system/(?:config|docs|modules|src|tests|tools|cloudflare|vendor))(?:/|$) - [F,L,NC]
RewriteRule ^storage/(?!uploads/).*$ - [F,L,NC]
RewriteRule ^(?:vendor)(?:/|$) - [F,L,NC]

# Route unknown requests through the front controller.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]
</IfModule>

<IfModule mod_setenvif.c>
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

<IfModule mod_authz_core.c>
<FilesMatch "(?i)\.(?:env|ini|log|md|markdown|pem|key|crt|sql|sqlite3?|toml|txt|ya?ml|zip|bak|dist|old)$">
    Require all denied
</FilesMatch>
<FilesMatch "^(?i:composer\.(json|lock))$">
    Require all denied
</FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
<FilesMatch "(?i)\.(?:env|ini|log|md|markdown|pem|key|crt|sql|sqlite3?|toml|txt|ya?ml|zip|bak|dist|old)$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^(?i:composer\.(json|lock))$">
    Order allow,deny
    Deny from all
</FilesMatch>
</IfModule>
