{
  "name": "metis/core",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "stripe/stripe-php": "^16.6",
    "dompdf/dompdf": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Metis\\": "system/src/Metis/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "vendor-dir": "system/vendor",
    "platform": {
      "php": "8.1.0"
    }
  }
}
