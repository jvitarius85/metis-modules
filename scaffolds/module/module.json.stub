{
  "slug": "{{module_slug}}",
  "label": "{{ModuleName}}",
  "default_view": "dashboard",
  "description": "{{ModuleName}} module",
  "views": {
    "dashboard": "dashboard.php"
  },
  "permissions": {
    "view": {
      "key": "{{module_slug}}.view",
      "action": "view",
      "name": "{{ModuleName}} View",
      "roles": []
    },
    "edit": {
      "key": "{{module_slug}}.edit",
      "action": "edit",
      "name": "{{ModuleName}} Edit",
      "roles": []
    }
  }
}
