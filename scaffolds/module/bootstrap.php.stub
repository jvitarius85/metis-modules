<?php
declare(strict_types=1);

if ( ! defined( 'ABSPATH' ) ) {
    exit;
}

require_once dirname( __DIR__, 2 ) . '/core/autoload.php';

\Metis\Modules\{{ModuleName}}\{{ModuleName}}Module::boot();

function metis_{{module_slug}}_base_url(): string {
    return \Metis\Modules\{{ModuleName}}\{{ModuleName}}Module::baseUrl();
}
