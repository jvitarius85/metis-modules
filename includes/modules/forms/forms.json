    "create": {
      "key": "forms.create",
      "action": "create",
      "name": "Forms Create",
      "roles": ["administrator", "board", "donor_admin", "newsletter_admin"]
    },
    "delete": {
      "key": "forms.delete",
      "action": "delete",
      "name": "Forms Delete",
      "roles": ["administrator", "board", "donor_admin", "newsletter_admin"]
    }
  },
  "views": {
    "dashboard": "dashboard.php",
    "form": "form.php",
    "build": "build.php",
    "entries": "entries.php",
    "settings": "settings.php"
