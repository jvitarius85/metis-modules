  "routes": [
    {
      "name": "forms.public",
      "methods": ["GET", "POST"],
      "pattern": "#^/public/forms/(?P<form_slug>[a-z0-9\\-]+)/?$#",
      "handler": "metis_forms_handle_public_route"
