Options -Indexes

<IfModule mod_php.c>
php_flag engine off
</IfModule>

<IfModule mod_php7.c>
php_flag engine off
</IfModule>

<IfModule mod_php8.c>
php_flag engine off
</IfModule>

<IfModule mod_php5.c>
php_flag engine off
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule "(^|/)\.(?!well-known/)" - [F,L]
RewriteRule ".*\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh|bash|zsh|cmd|exe|com|dll|so|jsp|asp|aspx)$" - [F,L,NC]
RewriteRule "!^[A-Fa-f0-9]{32}\.(?:jpg|jpeg|png|gif|webp|svg|pdf|txt|csv|json|doc|docx|xls|xlsx|ppt|pptx|zip)$" - [F,L,NC]
</IfModule>

<IfModule mod_authz_core.c>
<FilesMatch "(?i)\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh|bash|zsh|cmd|exe|com|dll|so|jsp|asp|aspx)$">
    Require all denied
</FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
<FilesMatch "(?i)\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh|bash|zsh|cmd|exe|com|dll|so|jsp|asp|aspx)$">
    Order allow,deny
    Deny from all
</FilesMatch>
</IfModule>
