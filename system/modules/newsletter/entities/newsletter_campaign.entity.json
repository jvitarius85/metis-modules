{
  "schema_version": 1,
  "entity": "newsletter_campaign",
  "label": "Newsletter campaign",
  "plural": "newsletter campaigns",
  "prefix": "NLC",
  "table_key": "newsletter_campaigns",
  "primary_key": "id",
  "uid_column": "newsletter_campaign_uid",
  "module": "newsletter",
  "aliases": ["newsletter", "newsletters", "newsletter campaign", "email campaign", "blast"],

  "fields": {
    "id":                     { "type": "integer",  "label": "ID",           "filterable": true, "sortable": true  },
    "newsletter_campaign_uid":{ "type": "string",   "label": "UID",          "filterable": true, "sortable": false },
    "name":                   { "type": "string",   "label": "Name",         "filterable": true, "sortable": true  },
    "subject":                { "type": "string",   "label": "Subject",      "filterable": true, "sortable": true  },
    "status":                 { "type": "string",   "label": "Status",       "filterable": true, "sortable": true,  "groupable": true    },
    "sent_count":             { "type": "integer",  "label": "Sent count",   "filterable": true, "sortable": true,  "aggregatable": true },
    "open_count":             { "type": "integer",  "label": "Opens",        "filterable": true, "sortable": true,  "aggregatable": true },
    "click_count":            { "type": "integer",  "label": "Clicks",       "filterable": true, "sortable": true,  "aggregatable": true },
    "scheduled_at":           { "type": "datetime", "label": "Scheduled",    "filterable": true, "sortable": true,  "date_field": true   },
    "sent_at":                { "type": "datetime", "label": "Sent",         "filterable": true, "sortable": true,  "date_field": true   },
    "created_at":             { "type": "datetime", "label": "Created",      "filterable": true, "sortable": true,  "date_field": true   }
  },

  "relationships": {},

  "reporting": {
    "aggregate_fields":  ["sent_count", "open_count", "click_count"],
    "groupable_fields":  ["status"],
    "filterable_fields": ["status", "scheduled_at", "sent_at", "created_at"],
    "date_fields":       ["scheduled_at", "sent_at", "created_at"],
    "default_sort":      "scheduled_at",
    "default_sort_dir":  "desc"
  },

  "permissions": { "view": "newsletter.view", "edit": "newsletter.manage" }
}
