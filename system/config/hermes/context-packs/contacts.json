{
  "type": "context_pack",
  "key": "contacts",
  "version": 1,
  "module_slug": "contacts",
  "title": "Contacts Context Pack",
  "description": "Structured knowledge for constituent records, notes, relationships, and contact hygiene work.",
  "source_modules": [
    "contacts",
    "people",
    "newsletter"
  ],
  "objects": [
    {
      "key": "contact",
      "name": "Contact",
      "description": "Primary constituent profile used across donations, communications, forms, and inventory workflows.",
      "identifiers": [
        "cid",
        "id",
        "email"
      ],
      "important_fields": [
        "first_name",
        "last_name",
        "email",
        "status",
        "source",
        "created_at"
      ]
    },
    {
      "key": "contact_detail",
      "name": "Contact Detail",
      "description": "Additional emails, phone numbers, addresses, and structured profile detail rows.",
      "identifiers": [
        "contact_cid",
        "contact_id"
      ],
      "important_fields": [
        "phone",
        "address",
        "label",
        "preferred"
      ]
    },
    {
      "key": "contact_note",
      "name": "Contact Note",
      "description": "Operational history and follow-up notes tied to a contact.",
      "identifiers": [
        "note_id",
        "contact_cid"
      ],
      "important_fields": [
        "body",
        "created_by",
        "created_at"
      ]
    },
    {
      "key": "newsletter_subscription",
      "name": "Newsletter Subscription",
      "description": "List enrollment and suppression state attached to a contact.",
      "identifiers": [
        "contact_cid",
        "list_id"
      ],
      "important_fields": [
        "list_name",
        "status",
        "subscribed_at",
        "suppressed_at"
      ]
    }
  ],
  "relationships": [
    {
      "from": "contact",
      "to": "contact_detail",
      "type": "has_many",
      "description": "A contact may own multiple phone, address, and auxiliary detail records."
    },
    {
      "from": "contact",
      "to": "contact_note",
      "type": "has_many",
      "description": "Notes capture history, merge rationale, and follow-up context."
    },
    {
      "from": "contact",
      "to": "newsletter_subscription",
      "type": "has_many",
      "description": "Communications eligibility depends on active list subscriptions and suppressions."
    }
  ],
  "permissions": [
    {
      "action": "view",
      "permission_key": "contacts.view",
      "allowed_roles": [
        "board",
        "donor_admin",
        "donor_user",
        "newsletter_admin"
      ]
    },
    {
      "action": "edit",
      "permission_key": "contacts.edit",
      "allowed_roles": [
        "board",
        "donor_admin",
        "newsletter_admin"
      ]
    },
    {
      "action": "create",
      "permission_key": "contacts.create",
      "allowed_roles": [
        "board",
        "donor_admin",
        "newsletter_admin"
      ]
    },
    {
      "action": "delete",
      "permission_key": "contacts.delete",
      "allowed_roles": [
        "board",
        "donor_admin",
        "newsletter_admin"
      ]
    }
  ],
  "available_actions": [
    {
      "key": "contacts.lookup",
      "category": "context",
      "description": "Load a contact profile, details, notes, relationships, and linked activity summary.",
      "required_permission": "view"
    },
    {
      "key": "contacts.subscription_audit",
      "category": "diagnostic",
      "description": "Inspect newsletter enrollment, duplicate addresses, and suppression mismatches.",
      "required_permission": "view"
    },
    {
      "key": "contacts.profile_update",
      "category": "action_proposal",
      "description": "Prepare a contact detail correction or merge proposal for approval.",
      "required_permission": "edit"
    }
  ],
  "diagnostics": [
    {
      "key": "duplicate_contact_check",
      "purpose": "Detect likely duplicate records before merges or donor attribution changes.",
      "evidence": [
        "shared email",
        "matching name",
        "overlapping phone"
      ],
      "severity": "medium"
    },
    {
      "key": "subscription_consistency",
      "purpose": "Find mismatches between contact lists, suppressions, and newsletter targeting eligibility.",
      "evidence": [
        "list membership",
        "suppression state",
        "campaign audience"
      ],
      "severity": "medium"
    }
  ],
  "common_operational_issues": [
    {
      "issue": "Duplicate contacts fragment giving and communication history.",
      "symptoms": [
        "same email on multiple records",
        "missing donation totals",
        "newsletter sends to wrong profile"
      ],
      "likely_causes": [
        "manual imports",
        "form submissions creating net-new records",
        "incomplete merge follow-through"
      ],
      "recommended_playbooks": [
        "permission_diagnostics",
        "system_health_diagnostics"
      ]
    },
    {
      "issue": "Contact cannot be targeted for announcements.",
      "symptoms": [
        "missing from audience preview",
        "suppressed unexpectedly"
      ],
      "likely_causes": [
        "subscription suppression",
        "segment rule mismatch",
        "record missing email"
      ],
      "recommended_playbooks": [
        "announcement_workflows",
        "permission_diagnostics"
      ]
    }
  ]
}
