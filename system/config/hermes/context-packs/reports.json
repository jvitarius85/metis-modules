{
  "type": "context_pack",
  "key": "reports",
  "version": 1,
  "module_slug": "finance",
  "title": "Reports Context Pack",
  "description": "Structured knowledge for cross-module reporting, dashboards, filters, snapshots, and export-oriented operational analysis.",
  "source_modules": [
    "finance",
    "donations",
    "newsletter",
    "board",
    "forms",
    "grandys_stash"
  ],
  "objects": [
    {
      "key": "report_definition",
      "name": "Report Definition",
      "description": "Named analytical view or report with filters, grouping, and output goals.",
      "identifiers": [
        "report_key",
        "slug"
      ],
      "important_fields": [
        "module_scope",
        "metric_set",
        "date_granularity"
      ]
    },
    {
      "key": "report_filter",
      "name": "Report Filter",
      "description": "Bounded filter criteria applied to report generation.",
      "identifiers": [
        "filter_key"
      ],
      "important_fields": [
        "date_from",
        "date_to",
        "status",
        "campaign_id"
      ]
    },
    {
      "key": "dashboard_snapshot",
      "name": "Dashboard Snapshot",
      "description": "Pre-aggregated summary used to keep operational dashboards responsive.",
      "identifiers": [
        "snapshot_key",
        "captured_at"
      ],
      "important_fields": [
        "module_scope",
        "metric_count",
        "staleness_seconds"
      ]
    }
  ],
  "relationships": [
    {
      "from": "report_definition",
      "to": "report_filter",
      "type": "uses_many",
      "description": "Definitions are parameterized by bounded filters and date windows."
    },
    {
      "from": "report_definition",
      "to": "dashboard_snapshot",
      "type": "may_cache_as",
      "description": "Expensive reports can be materialized into snapshots for dashboard use."
    }
  ],
  "permissions": [
    {
      "action": "view",
      "permission_key": "finance.view",
      "allowed_roles": [
        "administrator",
        "finance"
      ]
    },
    {
      "action": "edit",
      "permission_key": "finance.edit",
      "allowed_roles": [
        "finance"
      ]
    }
  ],
  "available_actions": [
    {
      "key": "reports.snapshot_lookup",
      "category": "context",
      "description": "Load cross-module summaries and cached dashboard evidence for a requested period.",
      "required_permission": "view"
    },
    {
      "key": "reports.aggregation_health",
      "category": "diagnostic",
      "description": "Inspect stale snapshots, missing filters, and expensive unbounded report requests.",
      "required_permission": "view"
    },
    {
      "key": "reports.refresh_proposal",
      "category": "action_proposal",
      "description": "Prepare a report refresh or export generation proposal for approval.",
      "required_permission": "edit"
    }
  ],
  "diagnostics": [
    {
      "key": "snapshot_staleness",
      "purpose": "Keep dashboard summaries responsive by surfacing stale or missing cache layers.",
      "evidence": [
        "captured_at",
        "staleness_seconds",
        "job status"
      ],
      "severity": "medium"
    },
    {
      "key": "unbounded_report_detection",
      "purpose": "Prevent large report requests from loading entire datasets synchronously.",
      "evidence": [
        "missing pagination",
        "wide date range",
        "no grouping filter"
      ],
      "severity": "high"
    }
  ],
  "common_operational_issues": [
    {
      "issue": "Operational report is slow or inconsistent across modules.",
      "symptoms": [
        "dashboard lag",
        "different totals by screen"
      ],
      "likely_causes": [
        "stale snapshots",
        "different filter windows",
        "module-specific aggregation drift"
      ],
      "recommended_playbooks": [
        "system_health_diagnostics",
        "donation_reconciliation"
      ]
    },
    {
      "issue": "Requested export pulls too much live data in-request.",
      "symptoms": [
        "timeouts",
        "memory pressure",
        "partial exports"
      ],
      "likely_causes": [
        "no cache",
        "no pagination",
        "cross-module joins executed synchronously"
      ],
      "recommended_playbooks": [
        "system_health_diagnostics",
        "inventory_verification"
      ]
    }
  ]
}
