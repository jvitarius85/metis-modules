{
  "type": "mission",
  "key": "publishing_announcements",
  "version": 1,
  "title": "Publishing Announcements",
  "objective": "Validate audience, content dependencies, and delivery readiness for a public or internal announcement.",
  "required_context_packs": [
    "communications",
    "cms_content",
    "contacts"
  ],
  "default_playbooks": [
    "announcement_workflows",
    "content_publishing_workflows",
    "permission_diagnostics"
  ],
  "phases": [
    {
      "key": "audience_validation",
      "playbooks": [
        "announcement_workflows"
      ],
      "outputs": [
        "audience scope",
        "suppression risks"
      ]
    },
    {
      "key": "content_readiness",
      "playbooks": [
        "content_publishing_workflows"
      ],
      "outputs": [
        "dependency status",
        "publish sequence"
      ]
    },
    {
      "key": "access_validation",
      "playbooks": [
        "permission_diagnostics"
      ],
      "outputs": [
        "approval and publish capability"
      ]
    }
  ],
  "approval_gates": [
    "campaign queue",
    "public content publish"
  ],
  "success_criteria": [
    "correct audience",
    "ready dependencies",
    "approved publication path"
  ]
}
