{
  "type": "mission",
  "key": "generating_operational_reports",
  "version": 1,
  "title": "Generating Operational Reports",
  "objective": "Produce a bounded, performant operational report bundle across module dashboards and analytical surfaces.",
  "required_context_packs": [
    "reports",
    "donations",
    "communications",
    "inventory",
    "board"
  ],
  "default_playbooks": [
    "system_health_diagnostics",
    "donation_reconciliation",
    "inventory_verification"
  ],
  "phases": [
    {
      "key": "report_scope",
      "playbooks": [
        "system_health_diagnostics"
      ],
      "outputs": [
        "available snapshots",
        "staleness flags"
      ]
    },
    {
      "key": "financial_and_operational_validation",
      "playbooks": [
        "donation_reconciliation",
        "inventory_verification"
      ],
      "outputs": [
        "validated totals",
        "inventory exceptions"
      ]
    },
    {
      "key": "bundle_generation",
      "playbooks": [
        "system_health_diagnostics"
      ],
      "outputs": [
        "bounded report bundle",
        "missing data disclosures"
      ]
    }
  ],
  "approval_gates": [
    "export generation if a refresh job or heavy query is required"
  ],
  "success_criteria": [
    "snapshots are fresh enough or flagged",
    "key metrics reconciled",
    "report scope stays bounded"
  ]
}
