{
  "type": "context_pack",
  "key": "board",
  "version": 1,
  "module_slug": "board",
  "title": "Board Context Pack",
  "description": "Structured knowledge for governance records, meeting workspaces, attendance, decisions, and compliance flows.",
  "source_modules": [
    "board",
    "drive",
    "people"
  ],
  "objects": [
    {
      "key": "meeting",
      "name": "Meeting",
      "description": "Board meeting record with schedule, workspace, attendance, and document packet linkage.",
      "identifiers": [
        "meeting_id",
        "meeting_code"
      ],
      "important_fields": [
        "scheduled_at",
        "status",
        "workspace_folder_id",
        "packet_status"
      ]
    },
    {
      "key": "decision",
      "name": "Decision",
      "description": "Board decision or decision template linked to a meeting and agenda context.",
      "identifiers": [
        "decision_id",
        "meeting_id"
      ],
      "important_fields": [
        "title",
        "status",
        "owner",
        "effective_date"
      ]
    },
    {
      "key": "action_item",
      "name": "Action Item",
      "description": "Follow-up work assigned during meetings.",
      "identifiers": [
        "action_item_id",
        "meeting_id"
      ],
      "important_fields": [
        "assignee",
        "due_date",
        "status"
      ]
    },
    {
      "key": "board_document",
      "name": "Board Document",
      "description": "Linked governance file used in packets or workspaces.",
      "identifiers": [
        "document_id",
        "drive_file_id"
      ],
      "important_fields": [
        "label",
        "folder_id",
        "linked_at"
      ]
    }
  ],
  "relationships": [
    {
      "from": "meeting",
      "to": "decision",
      "type": "has_many",
      "description": "Meetings capture decisions taken and templates applied."
    },
    {
      "from": "meeting",
      "to": "action_item",
      "type": "has_many",
      "description": "Action items convert governance outcomes into operational work."
    },
    {
      "from": "meeting",
      "to": "board_document",
      "type": "has_many",
      "description": "Packets and linked documents are attached to a meeting workspace."
    }
  ],
  "permissions": [
    {
      "action": "view",
      "permission_key": "board.view",
      "allowed_roles": [
        "board",
        "donor_admin",
        "newsletter_admin"
      ]
    },
    {
      "action": "edit",
      "permission_key": "board.edit",
      "allowed_roles": [
        "board"
      ]
    },
    {
      "action": "create",
      "permission_key": "board.create",
      "allowed_roles": [
        "board"
      ]
    },
    {
      "action": "delete",
      "permission_key": "board.delete",
      "allowed_roles": [
        "board"
      ]
    }
  ],
  "available_actions": [
    {
      "key": "board.meeting_workspace_snapshot",
      "category": "context",
      "description": "Load meeting metadata, attendance, packet readiness, and linked document inventory.",
      "required_permission": "view"
    },
    {
      "key": "board.access_diagnostic",
      "category": "diagnostic",
      "description": "Evaluate whether an actor can see meetings, documents, and packet preparation controls.",
      "required_permission": "view"
    },
    {
      "key": "board.meeting_preparation_proposal",
      "category": "action_proposal",
      "description": "Prepare agenda, workspace, packet, or announcement changes for approval.",
      "required_permission": "edit"
    }
  ],
  "diagnostics": [
    {
      "key": "workspace_link_integrity",
      "purpose": "Find meetings with missing drive folders, unlinked documents, or failed packet generation.",
      "evidence": [
        "meeting workspace folder",
        "document link count",
        "packet generation result"
      ],
      "severity": "high"
    },
    {
      "key": "role_access_mismatch",
      "purpose": "Detect cases where a board actor can see the dashboard but not meeting assets or actions.",
      "evidence": [
        "module permission",
        "workspace visibility",
        "feature availability"
      ],
      "severity": "high"
    }
  ],
  "common_operational_issues": [
    {
      "issue": "Board member can access the board dashboard but not a meeting workspace or packet.",
      "symptoms": [
        "missing document links",
        "access denied for packet assets"
      ],
      "likely_causes": [
        "role mismatch",
        "drive folder not linked",
        "workspace not prepared"
      ],
      "recommended_playbooks": [
        "board_access_troubleshooting",
        "permission_diagnostics"
      ]
    },
    {
      "issue": "Meeting prep is incomplete near the board date.",
      "symptoms": [
        "attendance not recorded",
        "packet generation missing",
        "announcements not published"
      ],
      "likely_causes": [
        "workspace setup skipped",
        "documents not linked",
        "downstream communications not queued"
      ],
      "recommended_playbooks": [
        "announcement_workflows",
        "system_health_diagnostics"
      ]
    }
  ]
}
